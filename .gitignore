# but they are not part of the public OpenMux source surface.
/.agents/
/.claude/
/.codex/
/.gemini/
/_bmad/
/_bmad-output/
/design-artifacts/

# Editor and OS files
/.idea/
/.vscode/
.DS_Store

# Local environment and secrets
.env
.env.*
!.env.example

# Logs and temporary files
*.log
*.tmp
*.temp

# Local OpenMux runtime data used during manual testing
/.openmux/
/dist/
/artifacts/
/release/
